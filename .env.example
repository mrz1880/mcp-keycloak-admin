# --- Keycloak connection ---
# Base URL of the Keycloak server (no trailing slash).
KEYCLOAK_BASE_URL=http://localhost:8080
# Realm the MCP server operates on.
KEYCLOAK_REALM=Pandi-Panda

# --- Authentication mode: service_account | password ---
AUTH_MODE=service_account

# Required when AUTH_MODE=service_account
# A confidential client with a service account holding the needed
# realm-management roles (see docs/setup-keycloak.md).
KC_CLIENT_ID=mcp-admin
KC_CLIENT_SECRET=change-me

# Required when AUTH_MODE=password
# An admin user; uses the admin-cli client on the admin realm.
KC_ADMIN_USERNAME=admin
KC_ADMIN_PASSWORD=change-me
KC_ADMIN_REALM=master

# --- Guardrails (optional) ---
# When true, write/destructive tools are not registered at all.
READ_ONLY=false
# Comma-separated allow-list of realms the server may operate on.
# Empty means all realms are allowed.
ALLOWED_REALMS=Pandi-Panda
